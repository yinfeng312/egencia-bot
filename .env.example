# Egencia 报账助手 环境变量配置
# 复制此文件为 .env 并填入真实值

# 飞书应用凭证（在飞书开发者后台 → 应用 → 凭证与基础信息）
FEISHU_APP_ID=cli_xxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# 多维表格配置（创建好表后填入）
# 在飞书多维表格 URL 中获取: https://feishu.cn/base/xxxxxxxAppToken
FEISHU_BITABLE_TOKEN=xxxxxxxAppToken

# Webhook 安全验证（可选，与飞书事件订阅配置保持一致）
WEBHOOK_VERIFY_TOKEN=egencia_bot_verify
# WEBHOOK_ENCRYPT_KEY=  # 可选，留空则不加密
